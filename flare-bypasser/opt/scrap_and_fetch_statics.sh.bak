#!/bin/bash

NATURAL_DOMAIN_LOL="https://tgstat.su"
FLARESOLVERR_URL="http://localhost:20080"
ORIGINAL_DOMAIN="https://tgstat.ru"
STATIC_DIR="/opt/flare-bypasser/www"
LOG_FILE="/opt/flare-bypasser/var/log/scrapping.log"
STATIC_LIST="/opt/flare-bypasser/var/cache/static_urls.txt"

mkdir -p "$STATIC_DIR"
mkdir -p "$(dirname "$LOG_FILE")"
mkdir -p "$(dirname "$STATIC_LIST")"

if [[ -z "$1" ]]; then
    echo "Использование: $0 <URL | файл HTML>"
    exit 1
fi

USERNAME=$(echo "$1" | grep -oP "@\K[\w\d-]+" || echo "page")
OUTPUT_FILE="/opt/flare-bypasser/www/channel/@$USERNAME.html"

# Очистка списка статики
> "$STATIC_LIST"
> "LOG_FILE"

INPUT="$1"

# Если передан HTML-файл, читаем его, иначе запрашиваем через Flare-Bypasser
if [[ -f "$INPUT" ]]; then
    echo "Использую локальный файл: $INPUT" | tee -a "$LOG_FILE"
    PAGE_CONTENT=$(cat "$INPUT")
else
    echo "Запрашиваю страницу через Flare-Bypasser: $INPUT" | tee -a "$LOG_FILE"

    PAGE_CONTENT=$(curl -s -X POST "$FLARESOLVERR_URL/v1" -H "Content-Type: application/json" --data-raw "{
      \"cmd\": \"request.get\",
      \"url\": \"$1\",
      \"maxTimeout\": 60000
    }" | jq -r ".solution.response")

    if [[ -z "$PAGE_CONTENT" || "$PAGE_CONTENT" == "null" ]]; then
        echo "Ошибка: не удалось получить страницу $INPUT" | tee -a "$LOG_FILE"
        exit 1
    fi
fi

# Сохранение страницы
echo "$PAGE_CONTENT" > "$OUTPUT_FILE"

# 🛠️ Добавляем <base> в <head> (чтобы браузер сам делал ссылки абсолютными)
BASE_URL="$ORIGINAL_DOMAIN"
sed -i "s|<head>|<head><base href=\"$BASE_URL\" />|" "$OUTPUT_FILE"

# 🛠️ Обрабатываем ссылки: href, src
if command -v pup >/dev/null 2>&1; then
    cat "$OUTPUT_FILE" | pup 'a[href], img[src], script[src], link[href]' attr{} | while read -r line; do
        TAG=$(echo "$line" | cut -d' ' -f1)
        ATTR=$(echo "$line" | cut -d' ' -f2 | cut -d'=' -f1)
        VALUE=$(echo "$line" | cut -d' ' -f2- | sed 's/^.*="//' | sed 's/"$//')

        if [[ "$VALUE" =~ ^/[^/] ]]; then
            ABSOLUTE_URL="${BASE_URL}${VALUE}"
            sed -i "s|$VALUE|$ABSOLUTE_URL|g" "$OUTPUT_FILE"
        fi
    done
else
    echo "⚠️  'pup' не установлен! Используем grep вместо него." | tee -a "$LOG_FILE"
    grep -oE '(href|src)="[^"]+"' "$OUTPUT_FILE" | cut -d'"' -f2 | grep "^/" | while read -r VALUE; do
        ABSOLUTE_URL="${BASE_URL}${VALUE}"
        sed -i "s|$VALUE|$ABSOLUTE_URL|g" "$OUTPUT_FILE"
    done
fi

echo "✅ Все ссылки обновлены и сохранены в $OUTPUT_FILE" | tee -a "$LOG_FILE"
